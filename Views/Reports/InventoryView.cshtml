@model IEnumerable<AssetTracker.Models.Reports.AssetRegisterRowVm>

@{
    ViewData["Title"] = "Full Asset Register";
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h3 mb-1">Full Asset Register</h1>
        <p class="text-secondary mb-0">Filtered inventory register output.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Reports</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Asset Tag</th>
                    <th>Serial</th>
                    <th>Brand</th>
                    <th>Model</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Department</th>
                    <th>Location</th>
                    <th>Assignee</th>
                    <th>Target</th>
                    <th>Assigned At</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model)
            {
                <tr>
                    <td>@row.AssetTag</td>
                    <td>@row.SerialNumber</td>
                    <td>@row.Brand</td>
                    <td>@row.Model</td>
                    <td>@row.Type</td>
                    <td>@row.Status</td>
                    <td>@row.Department</td>
                    <td>@row.Location</td>
                    <td>@row.AssigneeLabel</td>
                    <td>@row.TargetType</td>
                    <td>@(row.AssignedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    <td>@row.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
