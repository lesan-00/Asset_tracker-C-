@model AssetTracker.Models.Asset

@{
    ViewData["Title"] = "Delete Asset";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h1 class="h4 mb-0 text-danger">Delete Asset</h1>
            </div>
            <div class="card-body">
                <p class="mb-4">Are you sure you want to delete this asset?</p>

                <dl class="row">
                    <dt class="col-sm-4">Asset Tag</dt>
                    <dd class="col-sm-8">@Model.AssetTag</dd>

                    <dt class="col-sm-4">Serial Number</dt>
                    <dd class="col-sm-8">@Model.SerialNumber</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4">Location</dt>
                    <dd class="col-sm-8">@Model.Location</dd>
                </dl>

                <form asp-action="Delete" class="d-flex gap-2">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
