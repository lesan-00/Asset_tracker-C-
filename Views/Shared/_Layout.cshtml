<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Asset Tracker</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
</head>
<body class="app-shell">
    <div class="d-flex min-vh-100">
        <aside class="app-sidebar d-flex flex-column p-3">
            <a asp-controller="Dashboard" asp-action="Index" class="sidebar-brand text-decoration-none mb-4">
                Asset Tracker
            </a>

            <ul class="navbar-nav flex-grow-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
                </li>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Assets" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Assets</a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Assignments" asp-action="Index"><i class="bi bi-clipboard-check me-2"></i>Assignments</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Staff" asp-action="Index"><i class="bi bi-people me-2"></i>Staff</a>
                </li>
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Issues" asp-action="Index"><i class="bi bi-exclamation-triangle me-2"></i>Issues</a>
                    </li>
                }
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Reports" asp-action="Inventory"><i class="bi bi-bar-chart me-2"></i>Reports</a>
                    </li>
                }
            </ul>
        </aside>

        <div class="app-main flex-grow-1 d-flex flex-column">
            <header class="topbar border-bottom bg-white px-4 py-2">
                <div class="d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0 text-body-secondary">@ViewData["Title"]</h1>

                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-light border" type="button" aria-label="Notifications">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-bell" viewBox="0 0 16 16">
                                <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2z" />
                                <path d="M8 1.918c-2.22 0-4 1.79-4 4v2.086c0 .436-.106.865-.308 1.248L2.31 11.6A1 1 0 0 0 3.2 13h9.6a1 1 0 0 0 .89-1.4l-1.383-2.348A2.7 2.7 0 0 1 12 8.004V5.918c0-2.21-1.78-4-4-4zM8 0a5 5 0 0 1 5 5.918v2.086c0 .6.146 1.193.424 1.706l1.383 2.348A2 2 0 0 1 12.8 14H3.2a2 2 0 0 1-2.007-1.942c-.02-.43.105-.857.359-1.258l1.383-2.348c.278-.513.424-1.106.424-1.706V5.918A5 5 0 0 1 8 0z" />
                            </svg>
                        </button>

                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Profile
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-2">
                                <partial name="_LoginPartial" />
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="p-4 flex-grow-1">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


