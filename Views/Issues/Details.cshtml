@model AssetTracker.Models.Issue

@{
    ViewData["Title"] = "Issue Details";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h1 class="h4 mb-0">Issue Details</h1>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
            }
        </div>
    </div>
    <div class="card-body">
        <dl class="row mb-4">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category</dd>

            <dt class="col-sm-3">Priority</dt>
            <dd class="col-sm-9">@Model.Priority</dd>

            <dt class="col-sm-3">Asset</dt>
            <dd class="col-sm-9">@(Model.Asset?.AssetTag ?? "-")</dd>

            <dt class="col-sm-3">Created By</dt>
            <dd class="col-sm-9">@Model.CreatedByUser.Email</dd>

            <dt class="col-sm-3">Assigned To</dt>
            <dd class="col-sm-9">@(Model.AssignedToUser?.Email ?? "-")</dd>

            <dt class="col-sm-3">Reported For</dt>
            <dd class="col-sm-9">@(Model.ReportedForStaffProfile?.FullName ?? "-")</dd>

            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Updated At</dt>
            <dd class="col-sm-9">@(Model.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
        </dl>

        <div class="border rounded p-3 bg-light">
            <h2 class="h6 mb-2">Description</h2>
            <p class="mb-0">@Model.Description</p>
        </div>
    </div>
</div>
