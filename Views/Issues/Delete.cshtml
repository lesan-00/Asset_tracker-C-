@model AssetTracker.Models.Issue

@{
    ViewData["Title"] = "Delete Issue";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h1 class="h4 mb-0 text-danger">Delete Issue</h1>
            </div>
            <div class="card-body">
                <p class="mb-4">Are you sure you want to delete this issue?</p>

                <dl class="row">
                    <dt class="col-sm-4">Title</dt>
                    <dd class="col-sm-8">@Model.Title</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4">Priority</dt>
                    <dd class="col-sm-8">@Model.Priority</dd>

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category</dd>

                    <dt class="col-sm-4">Asset</dt>
                    <dd class="col-sm-8">@(Model.Asset?.AssetTag ?? "-")</dd>
                </dl>

                <form asp-action="Delete" class="d-flex gap-2">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
