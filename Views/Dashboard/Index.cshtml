@model AssetTracker.Models.DashboardVm

@{
    ViewData["Title"] = "Dashboard";

    static string PriorityBadgeClass(AssetTracker.Models.IssuePriority priority)
    {
        return priority switch
        {
            AssetTracker.Models.IssuePriority.High => "badge-soft-danger",
            AssetTracker.Models.IssuePriority.Medium => "badge-soft-warning",
            _ => "badge-soft-secondary"
        };
    }
}

<div class="dashboard-page">
    <section class="dashboard-hero">
        <div>
            <h2 class="dashboard-title">Asset Operations Overview</h2>
            <p class="dashboard-subtitle mb-0">Track core inventory health and allocation at a glance.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-controller="Assets" asp-action="Create" class="btn btn-primary">Add Asset</a>
            <a asp-controller="Assignments" asp-action="Create" class="btn btn-outline-primary">Assign</a>
        </div>
    </section>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">Total Assets</div>
                    <div class="kpi-value">@Model.TotalAssets</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">In Stock</div>
                    <div class="kpi-value">@Model.InStock</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">Assigned</div>
                    <div class="kpi-value">@Model.Assigned</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card kpi-card h-100">
                <div class="card-body">
                    <div class="kpi-label">In Repair</div>
                    <div class="kpi-value">@Model.InRepair</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="card panel-card h-100">
                <div class="card-header panel-header d-flex justify-content-between align-items-center">
                    <h3 class="panel-title mb-0">Allocation by Department</h3>
                    <span class="badge text-bg-light">Assigned: @Model.Assigned</span>
                </div>
                <div class="card-body panel-body">
                    @if (Model.AllocationByDepartment.Count == 0)
                    {
                        <p class="text-secondary mb-0">No department allocation data.</p>
                    }
                    else
                    {
                        @foreach (var item in Model.AllocationByDepartment)
                        {
                            <div class="allocation-item">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="fw-medium">@item.DepartmentName</span>
                                    <span class="text-secondary">@item.Count (@item.Percent%)</span>
                                </div>
                                <div class="allocation-track">
                                    <div class="allocation-fill" role="progressbar" style="width:@item.Percent%"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card panel-card h-100">
                <div class="card-header panel-header d-flex justify-content-between align-items-center">
                    <h3 class="panel-title mb-0">Open Issues</h3>
                    <a asp-controller="Issues" asp-action="Index" class="small fw-semibold text-decoration-none">View all</a>
                </div>
                <div class="list-group list-group-flush">
                    @if (Model.LatestOpenIssues.Count == 0)
                    {
                        <div class="list-group-item text-secondary">No open issues.</div>
                    }
                    else
                    {
                        @foreach (var issue in Model.LatestOpenIssues)
                        {
                            <a asp-controller="Issues" asp-action="Details" asp-route-id="@issue.Id" class="list-group-item list-group-item-action issue-row">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="fw-semibold">@issue.Title</div>
                                        <div class="text-secondary small">@issue.AssetTag • @issue.CreatedAt.ToLocalTime().ToString("g")</div>
                                    </div>
                                    <span class="badge @PriorityBadgeClass(issue.Priority)">@issue.Priority</span>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card panel-card">
        <div class="card-header panel-header">
            <h3 class="panel-title mb-0">Recent Activity</h3>
        </div>
        <div class="list-group list-group-flush panel-list-scroll">
            @if (Model.RecentActivity.Count == 0)
            {
                <div class="list-group-item text-secondary">No recent activity.</div>
            }
            else
            {
                @foreach (var activity in Model.RecentActivity)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">@activity.Message</div>
                            <div class="text-secondary small text-uppercase">@activity.Type</div>
                        </div>
                        <div class="text-secondary small">@activity.OccurredAt.ToLocalTime().ToString("g")</div>
                    </div>
                }
            }
        </div>
    </div>
</div>

