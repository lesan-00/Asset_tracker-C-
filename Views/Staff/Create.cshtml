@model AssetTracker.Models.StaffProfile

@{
    ViewData["Title"] = "Create Staff Profile";
}

<style>
    .profile-card {
        border: 1px solid #e9ecef;
        border-radius: 16px;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        background-color: #fff;
    }

    .profile-card-body {
        padding: 32px;
    }

    .field-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6c757d;
        font-weight: 600;
    }

    .form-control,
    .form-select {
        min-height: 44px;
        border-radius: 12px;
    }

    .btn-pill {
        border-radius: 999px;
    }

    .asset-panel {
        border: 1px solid #e9ecef;
        border-radius: 12px;
        background-color: #f8f9fa;
    }
</style>

<div class="row justify-content-center">
    <div class="col-12 col-xl-10">
        <div class="profile-card">
            <div class="profile-card-body">
                <div class="mb-4">
                    <h1 class="display-6 fw-bold mb-1">Create Staff Profile</h1>
                    <p class="text-muted mb-0">Add a new staff member to the system</p>
                </div>

                <hr class="mb-4" />

                <form asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-4"></div>
                    <input asp-for="UserId" type="hidden" />

                    <div class="row">
                        <div class="col-12 col-lg-6 pe-lg-4">
                            <div class="mb-4">
                                <label for="UserEmail" class="form-label field-label">Identity User (Email)</label>
                                <input id="UserEmail"
                                       name="userEmail"
                                       type="email"
                                       class="form-control"
                                       value="@ViewData["SelectedUserEmail"]"
                                       list="identity-users"
                                       placeholder="Enter staff email" />
                                <datalist id="identity-users">
                                    @if (ViewData["UserEmails"] is IEnumerable<string> emails)
                                    {
                                        foreach (var email in emails)
                                        {
                                            <option value="@email"></option>
                                        }
                                    }
                                </datalist>
                                <span asp-validation-for="UserId" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="asset-panel p-3 mb-4">
                                <div class="field-label mb-2">Assigned Asset</div>
                                <div id="assigned-asset-text" class="fw-semibold">@ViewData["AssignedAssetText"]</div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="EmployeeNumber" class="form-label field-label"></label>
                                <input asp-for="EmployeeNumber" class="form-control" />
                                <span asp-validation-for="EmployeeNumber" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="PhoneNumber" class="form-label field-label"></label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 ps-lg-4">
                            <div class="mb-4">
                                <label asp-for="FullName" class="form-label field-label"></label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Department" class="form-label field-label"></label>
                                <input asp-for="Department" class="form-control" />
                                <span asp-validation-for="Department" class="text-danger small d-block mt-1"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-2">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">Cancel</a>
                        <button type="submit" class="btn btn-primary btn-pill px-4 py-2">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function () {
            const emailInput = document.getElementById("UserEmail");
            const assetText = document.getElementById("assigned-asset-text");

            if (!emailInput || !assetText) {
                return;
            }

            async function refreshAssignedAsset() {
                const email = emailInput.value.trim();
                if (!email) {
                    assetText.textContent = "None";
                    return;
                }

                try {
                    const response = await fetch(`/Staff/LookupAssignedAsset?email=${encodeURIComponent(email)}`);
                    if (!response.ok) {
                        assetText.textContent = "None";
                        return;
                    }

                    const data = await response.json();
                    assetText.textContent = data.assignedAsset || "None";
                } catch {
                    assetText.textContent = "None";
                }
            }

            emailInput.addEventListener("change", refreshAssignedAsset);
            emailInput.addEventListener("blur", refreshAssignedAsset);
        })();
    </script>
}
