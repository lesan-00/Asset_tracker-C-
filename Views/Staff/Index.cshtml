@model IEnumerable<AssetTracker.Models.StaffProfile>

@{
    ViewData["Title"] = "Staff";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Staff Profiles</h1>
    <a asp-action="Create" class="btn btn-primary">Add Staff Profile</a>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Employee Number</th>
                    <th>Department</th>
                    <th>Phone</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@(item.User?.Email ?? "-")</td>
                    <td>@item.EmployeeNumber</td>
                    <td>@item.Department</td>
                    <td>@item.PhoneNumber</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
