@using AssetTracker.Models
@model AssetTracker.Models.Assignments.AssignmentIndexVm

@{
    ViewData["Title"] = "Assignments";

    static AssignmentStatus DisplayStatus(AssignmentStatus status) => status switch
    {
        AssignmentStatus.PendingAcceptance => AssignmentStatus.Active,
        AssignmentStatus.Accepted => AssignmentStatus.Active,
        AssignmentStatus.ReturnRequested => AssignmentStatus.Active,
        AssignmentStatus.ReturnedApproved => AssignmentStatus.Returned,
        _ => status
    };

    static string GetBadgeClass(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Active => "bg-success-subtle text-success-emphasis",
        AssignmentStatus.Returned => "bg-primary-subtle text-primary-emphasis",
        AssignmentStatus.Reverted => "bg-warning-subtle text-warning-emphasis",
        _ => "bg-secondary-subtle text-secondary-emphasis"
    };
}

<style>
    .assignment-shell .card {
        border-radius: 14px;
    }

    .assignment-item .status-pill {
        border-radius: 999px;
        font-weight: 600;
        padding: .35rem .75rem;
    }
</style>

<div class="assignment-shell">
    @if (TempData["AssignmentSuccess"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="mb-4">
        <h1 class="h3 mb-1">Assignments</h1>
        <p class="text-secondary mb-0">Manage asset issuance and return workflows.</p>
    </div>

    <form method="get" class="d-flex flex-column flex-md-row gap-2 gap-md-3 mb-4">
        <input type="search" class="form-control" name="q" value="@Model.Query" placeholder="Search by asset/staff" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            <a asp-action="Create" class="btn btn-primary">+ New Assignment</a>
        </div>
    </form>

    @if (Model.Assignments.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body py-5 text-center">
                <h2 class="h5 mb-2">No assignments found</h2>
                <p class="text-secondary mb-4">Create your first assignment to start tracking issued assets.</p>
                <a asp-action="Create" class="btn btn-primary">+ New Assignment</a>
            </div>
        </div>
    }
    else
    {
        <div class="d-grid gap-3">
            @foreach (var item in Model.Assignments)
            {
                var dropdownId = $"assignment-actions-{item.AssignmentId}";
                var displayStatus = DisplayStatus(item.Status);
                var isActionable = displayStatus == AssignmentStatus.Active;

                <div class="card border-0 shadow-sm assignment-item">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h2 class="h5 mb-1">@item.AssetName to @item.StaffFullName</h2>
                                <span class="badge rounded-pill text-bg-light border">@item.AssetType</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="status-pill @GetBadgeClass(displayStatus)">@displayStatus</span>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary px-2" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Actions" id="@dropdownId">
                                        ...
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="@dropdownId">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.AssignmentId">Details</a></li>
                                        @if (isActionable)
                                        {
                                            <li>
                                                <form asp-action="MarkReturned" method="post" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.AssignmentId" />
                                                    <button type="submit" class="dropdown-item">Mark Returned</button>
                                                </form>
                                            </li>
                                            <li>
                                                <form asp-action="Revert" method="post" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.AssignmentId" />
                                                    <button type="submit" class="dropdown-item">Revert</button>
                                                </form>
                                            </li>
                                        }
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.AssignmentId">Delete</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="text-secondary mb-2">
                            <span class="fw-semibold">@item.AssetTag</span> / <span>@item.SerialNumber</span> | <span>@item.StaffFullName</span>
                        </div>
                        <div class="text-secondary d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M11 0a1 1 0 0 1 1 1v1h1.5A2.5 2.5 0 0 1 16 4.5v9A2.5 2.5 0 0 1 13.5 16h-11A2.5 2.5 0 0 1 0 13.5v-9A2.5 2.5 0 0 1 2.5 2H4V1a1 1 0 1 1 2 0v1h4V1a1 1 0 0 1 1-1M1 6v7.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5V6z" />
                            </svg>
                            <span>Issued on @item.IssuedDate.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

