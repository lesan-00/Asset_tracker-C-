@model AssetTracker.Models.Assignments.NewAssignmentVm

@{
    ViewData["Title"] = "New Assignment";
}

<style>
    .assignment-create-card {
        border-radius: 16px;
        border: 1px solid #e9ecef;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.1);
        background: #fff;
    }

    .assignment-create-body {
        background: #f8fafc;
        border-radius: 0 0 16px 16px;
    }

    .assignment-create-card .form-control,
    .assignment-create-card .form-select {
        border-radius: 14px;
    }

    .typeahead-wrap {
        position: relative;
    }

    .typeahead-list {
        position: absolute;
        z-index: 1080;
        top: 100%;
        left: 0;
        right: 0;
        margin-top: .25rem;
        padding: .25rem 0;
        list-style: none;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: .75rem;
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .12);
        max-height: 240px;
        overflow-y: auto;
    }

    .typeahead-item {
        padding: .5rem .75rem;
        cursor: pointer;
    }

    .typeahead-item.active,
    .typeahead-item:hover {
        background: #eef4ff;
    }

    .combo-toggle {
        min-width: 44px;
    }
</style>

<div class="container py-4">
    <div class="assignment-create-card">
        <div class="p-4 border-bottom">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="h4 mb-1">New Assignment</h1>
                    <p class="text-muted mb-0">Assignment is activated immediately on create.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>
        </div>
        <div class="assignment-create-body p-4">
            <form asp-action="Create" method="post" id="assignmentCreateForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3 mb-1">
                        <div class="col-md-6">
                            <label asp-for="AssetSearchText" class="form-label">Asset</label>
                            <div class="typeahead-wrap">
                                <div class="input-group">
                                    <input asp-for="AssetSearchText"
                                           class="form-control"
                                           id="assetSearchText"
                                           placeholder="Search asset by tag, serial, brand, or model..."
                                           autocomplete="off" />
                                    <button type="button" class="btn btn-outline-secondary combo-toggle" id="assetDropdownBtn" aria-label="Show asset suggestions">
                                        <span aria-hidden="true">&#9662;</span>
                                    </button>
                                </div>
                                <input asp-for="AssetId" type="hidden" id="assetIdHidden" />
                                <ul class="typeahead-list d-none" id="assetSuggestions" role="listbox"></ul>
                            </div>
                            <span asp-validation-for="AssetId" class="text-danger"></span>
                            <div class="text-danger small d-none" id="assetClientError">Please select a valid asset from the list.</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="IssueDate" class="form-label"></label>
                            <input asp-for="IssueDate" class="form-control" type="date" />
                            <span asp-validation-for="IssueDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TargetType" class="form-label d-block">Assignment Target</label>
                        <div class="d-flex flex-wrap gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="TargetType" id="targetStaff" value="Staff" />
                                <label class="form-check-label" for="targetStaff">Staff</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="TargetType" id="targetDepartment" value="Department" />
                                <label class="form-check-label" for="targetDepartment">Department</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="TargetType" id="targetLocation" value="Location" />
                                <label class="form-check-label" for="targetLocation">Location</label>
                            </div>
                        </div>
                        <span asp-validation-for="TargetType" class="text-danger"></span>
                    </div>

                    <div class="row g-3 mb-1">
                        <div class="col-12">
                            <label asp-for="ReceiverSearchText" class="form-label">Receiver</label>
                            <div class="typeahead-wrap">
                                <div class="input-group">
                                    <input asp-for="ReceiverSearchText"
                                           class="form-control"
                                           id="receiverSearchText"
                                           autocomplete="off" />
                                    <button type="button" class="btn btn-outline-secondary combo-toggle" id="receiverDropdownBtn" aria-label="Show staff suggestions">
                                        <span aria-hidden="true">&#9662;</span>
                                    </button>
                                </div>
                                <input asp-for="StaffProfileId" type="hidden" id="staffProfileIdHidden" />
                                <input asp-for="Department" type="hidden" id="departmentHidden" />
                                <input asp-for="Location" type="hidden" id="locationHidden" />
                                <ul class="typeahead-list d-none" id="receiverSuggestions" role="listbox"></ul>
                            </div>
                            <span asp-validation-for="StaffProfileId" class="text-danger"></span>
                            <span asp-validation-for="Department" class="text-danger d-block"></span>
                            <span asp-validation-for="Location" class="text-danger d-block"></span>
                            <div class="text-danger small d-none" id="staffClientError">Please select a valid staff member from the list.</div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="IssueCondition" class="form-label"></label>
                            <input asp-for="IssueCondition" class="form-control" />
                            <span asp-validation-for="IssueCondition" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                <div class="pt-4 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Create Assignment</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/assignment-modal.js" asp-append-version="true"></script>
}
